# Copy to .env and fill in. All variables use the INVOS_ prefix.

# Telegram bot token from @BotFather (required only for serve-telegram)
INVOS_TELEGRAM_BOT_TOKEN=

# dev | staging | prod
INVOS_ENVIRONMENT=dev

# fixture (data demo offline) | live (harga EOD + berita RSS sungguhan).
# WAJIB "live" untuk deployment nyata — CLI bisa pakai flag --live,
# tapi Docker/compose membaca nilai ini.
INVOS_DATA_MODE=fixture

# Emit JSON logs (recommended in prod)
INVOS_LOG_JSON=false

# HTTP Basic auth for the REST API + dashboard (all routes except /health).
# Leave empty only if the API stays on localhost/private network.
#INVOS_API_AUTH=admin:ganti-password-ini

# Host port/bind for the dockerized API (compose only). Change the port if
# 8000 is already taken; set bind 0.0.0.0 only together with INVOS_API_AUTH.
#INVOS_API_PORT=8000
#INVOS_API_BIND=127.0.0.1

# Mirror watchlist alerts to a webhook (in addition to Telegram).
# Format: generic (JSON event, cocok untuk n8n/custom) | discord | slack
#INVOS_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
#INVOS_ALERT_WEBHOOK_FORMAT=discord

# ---- LLM narrative layer (optional) ----
# Set ONE (or more) provider key; the first configured provider is used.
# Force a specific one with INVOS_LLM_PROVIDER, override the model with
# INVOS_LLM_MODEL. Without any key, analyses stay fully deterministic.
#ANTHROPIC_API_KEY=          # Anthropic (Claude) — pip install 'investment-os[anthropic]'
#OPENAI_API_KEY=             # OpenAI (GPT)
#GOOGLE_API_KEY=             # Google (Gemini)
#XAI_API_KEY=                # xAI (Grok)
#DEEPSEEK_API_KEY=           # DeepSeek
#DASHSCOPE_API_KEY=          # Qwen — international
#DASHSCOPE_CN_API_KEY=       # Qwen — China
#ZHIPU_API_KEY=              # GLM via Z.AI (international)
#ZHIPU_CN_API_KEY=           # GLM via BigModel (China)
#MINIMAX_API_KEY=            # MiniMax — global
#MINIMAX_CN_API_KEY=         # MiniMax — China
#OPENROUTER_API_KEY=         # OpenRouter
#INVOS_LLM_PROVIDER=anthropic
#INVOS_LLM_MODEL=

# Let the LLM take the news seat in the committee (deterministic lexicon
# analyst remains the automatic fallback). Requires a provider key above.
#INVOS_LLM_ANALYSTS=true
